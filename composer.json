{
    "name": "dvc/contao-jobs-importer-to-plenta-basic",
    "description": "Allows to import job offers into Plenta Jobs Basic from various sources.",
    "type": "contao-bundle",
    "version": "5.7.0",
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.3",
        "plenta/contao-jobs-basic-bundle": "3.*",
        "symfony/serializer": "^7.0",
        "dazet/data-map": "^0.2.0",
        "ezyang/htmlpurifier": "^4.17"
    },
    "conflict": {
        "plenta/contao-jobs-basic-bundle": "<3.0"
    },
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "Jonathan Hermann",
            "email": "jh@d-v-c.net"
        }
    ],
    "autoload": {
        "psr-4": {
            "DVC\\JobsImporterToPlentaBasic\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "DVC\\JobsImporterToPlentaBasic\\ContaoManager\\Plugin"
    }
}